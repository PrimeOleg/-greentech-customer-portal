<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/styles.css" />
    <title>Dashboard</title>
  </head>
  <body>
    <div class="container-fluid">
      <div class="row flex-nowrap">
        <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 bg-dark">
          <div
            class="d-flex flex-column align-items-center align-items-sm-start px-3 pt-2 text-white min-vh-100"
          >
            <a
              href="/"
              class="d-flex align-items-center pb-3 mb-md-0 me-md-auto text-white text-decoration-none"
            >
              <span class="fs-5 d-none d-sm-inline">Menu</span>
            </a>
            <ul
              class="nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start"
              id="menu"
            >
              <li>
                <a href="/dashboard" class="nav-link px-0">
                  <i class="fs-4 bi-speedometer2"></i>
                  <span class="ms-1 d-none d-sm-inline">Dashboard</span></a
                >
              </li>
              <li>
                <a href="/calculator" class="nav-link px-0 align-middle">
                  <i class="fs-4 bi bi-calculator"></i>
                  <span class="ms-1 d-none d-sm-inline">Carbon Calculator</span>
                </a>
              </li>
              <li>
                <a href="/booking" class="nav-link px-0 align-middle">
                  <i class="fs-4 bi bi-calendar"></i>
                  <span class="ms-1 d-none d-sm-inline">Bookings</span></a
                >
              </li>
              <li>
                <a href="/products" class="nav-link px-0 align-middle">
                  <i class="fs-4 bi bi-cart"></i>
                  <span class="ms-1 d-none d-sm-inline">Products</span>
                </a>
              </li>
            </ul>
            <hr />
            <div class="dropdown pb-4">
              <a
                href="#"
                class="d-flex align-items-center text-white text-decoration-none dropdown-toggle"
                id="dropdownUser1"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="bi bi-person-bounding-box"></i>
                <span class="d-none d-sm-inline mx-1"><%= user %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
                <li><a class="dropdown-item" href="/logout">Sign out</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col py-3">
          <div class="container">
            <header
              class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-between py-3 mb-4 border-bottom"
            >
              <ul
                class="nav col-12 col-md-auto mb-2 justify-content-center mb-md-0"
              >
                <li>
                  <a href="/" class="nav-link px-2 link-success">Home</a>
                </li>
                <li>
                  <a href="/calculator" class="nav-link link-success px-2"
                    >Carbon Calculator</a
                  >
                </li>
                <li>
                  <a href="/booking" class="nav-link link-success px-2"
                    >Bookings</a
                  >
                </li>
                <li>
                  <a href="/404" class="nav-link link-success px-2">Products</a>
                </li>
              </ul>

              <div class="col-md-3 text-end">
                <a href="/logout"
                  ><button type="button" class="btn btn-warning">
                    Logout
                  </button></a
                >
              </div>
            </header>
          </div>
          <div class="container my-5">
            <h2>Welcome <%= user %> here is your Bookings History</h2>
            <!--Displaying all the booking that the user has utilising ejs-->
            <% if (bookings.length === 0) { %>
            <h3>No bookings yet</h3>
            <% } else { %>
            <table class="table">
              <thead>
                <tr>
                  <th scope="col">Service</th>
                  <th scope="col">Date</th>
                  <th scope="col">Extra Notes</th>
                  <th scope="col">Delete?</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach(book => { %>
                <!-- Using for each loop to access the booking details based on the user-->
                <tr>
                  <td><%=book.service %></td>
                  <td><%=book.date_booked.toLocaleDateString("en-GB") %></td>
                  <!--Conversion into understandable date format-->
                  <td><%=book.extra_info %></td>
                  <td>
                    <form action="/delete-booking/<%=book.id %>" method="post">
                      <!--The following line was taken from ChatGPT4-->
                      <button type="submit" class="btn btn-danger">
                        Delete?
                      </button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
            <% } %>
            <!--TODO: Successful booking mesages informing the user for better user interactivity-->
            <h2>Your Energy Usage</h2>
            <canvas id="electricityChart"></canvas>
          </div>
          <!--TODO: Stick the footer to the bottom of the page-->
          <footer class="footer mt-auto py-3">
            <div class="container">
              <%-include("../public/partials/footer.ejs"); %>
            </div>
          </footer>
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      // VS code does not seem to recognise ejs tags and therefore detects a syntax error however everything works
      const ctx = document.getElementById("electricityChart");
      const electricityLabel = <%- JSON.stringify(electricityData.map(e => new Date(e.date_of_calculation).toLocaleDateString("en-GB"))) %>;
      const data = <%- JSON.stringify(electricityData.map(e => e.electricity_kwh)) %>;

      new Chart(ctx, {
        type: "line",
        data: {
          labels: electricityLabel,
          datasets: [
            {
              label: "electricity usage (kwh)",
              data: data,
              borderWidth: 1,
              backgroundColor: 'green'
            },
          ],
        },
        options: {
          scales: {
            y: {
              beginAtZero: true,
            },
          },
        },
      });
    </script>
  </body>
</html>
