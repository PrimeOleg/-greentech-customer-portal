<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/styles.css" />
    <title>Homepage</title>
  </head>
  <body>
    <%-include("../public/partials/header.ejs"); %>
    <div class="container col-xxl-8 px-4 py-5">
      <div class="row flex-lg-row-reverse align-items-center g-5 py-5">
        <div class="col-10 col-sm-8 col-lg-6">
          <img
            src="assets/hero_image.jpg"
            class="d-block mx-lg-auto img-fluid rounded-5"
            alt="Hero image of wind turbines"
            width="700"
            height="500"
            loading="lazy"
          />
        </div>
        <div class="col-lg-6">
          <h1 class="display-5 fw-bold text-body-emphasis lh-1 mb-3">
            Powering Tomorrow, Today.
          </h1>
          <p class="lead">
            Smart energy solutions for a cleaner, greener future — from solar
            panels to smart homes.
          </p>
          <div class="d-grid gap-2 d-md-flex justify-content-md-start">
            <a href="/login"
              ><button
                type="button"
                class="btn btn-lg px-4 btn-outline-warning"
              >
                Login
              </button></a
            >
            <a href="/signup"
              ><button
                type="button"
                class="btn btn-outline-warning btn-lg px-4"
              >
                Sign Up
              </button></a
            >
          </div>
        </div>
      </div>
    </div>
    <div class="container my-5 text-center">
      <h2>FOR TESTING ROUTES (REMOVE AFTER FULL RELEASE)</h2>
      <div class="card">
        <div class="card-header">
          <a href="/signup">Sign Up</a>
        </div>
        <div class="card-header">
          <a href="/login">Login</a>
        </div>
        <div class="card-header">
          <a href="/dashboard">Dashboard (Users Only)</a>
        </div>
        <div class="card-header">
          <a href="/calculator">Carbon calculator</a>
        </div>
        <div class="card-header">
          <a href="/booking">Service Bookings</a>
        </div>
      </div>
    </div>
    <div class="album py-5 bg-body-primary">
      <div class="container text-center">
        <h2>Current Green Products on the market</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 py-3">
          <div class="col">
            <div class="card shadow-sm">
              <img
                src="assets\solar-panel.jpg"
                alt="solar panel product image"
                width="100%"
                height="300"
              />
              <div class="card-body">
                <h2>Solar Starter Kit</h2>
                <p class="card-text">
                  Efficient, compact solar system for homes looking to reduce
                  energy bills and carbon emissions.
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group align-items-center">
                    <a href="/products"
                      ><button type="button" class="btn btn-warning">
                        View More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card shadow-sm">
              <img
                src="assets\electric-car.jpg"
                alt="solar panel product image"
                width="100%"
                height="300"
              />
              <div class="card-body">
                <h2>Smart EV Charger</h2>
                <p class="card-text">
                  Charge your vehicle faster and smarter with our app-controlled
                  home charging system.
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group">
                    <a href="/products"
                      ><button type="button" class="btn btn-warning">
                        View More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card shadow-sm">
              <img
                src="assets\energy-monitor.jpg"
                alt="solar panel product image"
                width="100%"
                height="300"
              />
              <div class="card-body">
                <h2>Energy Monitoring</h2>
                <p class="card-text">
                  Monitor your energy usage in real time to lower the energy
                  demands
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group">
                    <a href="/products"
                      ><button type="button" class="btn btn-warning">
                        View More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="album py-5 bg-body-primary">
      <div class="container text-center">
        <h2>
          How to reduce <span style="color: green">YOUR</span> carbon footprint
        </h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 py-3">
          <div class="col">
            <div class="card shadow-sm">
              <div class="card-body bg-body-tertiary">
                <h2>Why Solar Power is the Future</h2>
                <p class="card-text">
                  Explore the benefits of switching to solar and how it impacts
                  your energy bills and the planet.
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group align-items-center">
                    <a href="/blog"
                      ><button type="button" class="btn btn-warning">
                        Read More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card shadow-sm">
              <div class="card-body bg-body-tertiary">
                <h2>5 Ways to Save Energy in 2025</h2>
                <p class="card-text">
                  Discover simple changes that can lower your energy usage and
                  support a sustainable future
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group">
                    <a href="/blog"
                      ><button type="button" class="btn btn-warning">
                        Read More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="card shadow-sm">
              <div class="card-body bg-body-tertiary">
                <h2>Reasons to switch to green energy</h2>
                <p class="card-text">
                  How far can we go if we change to the green energy and how it
                  will benefit us
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <div class="btn-group">
                    <a href="/blog"
                      ><button type="button" class="btn btn-warning">
                        Read More
                      </button></a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <section class="py-5 text-center container bg-body-tertiary">
      <div class="row py-lg-5">
        <div class="col-lg-6 col-md-8 mx-auto">
          <svg class="bd-placeholder-img rounded-circle" width="140" height="140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder" preserveAspectRatio="xMidYMid slice"><title>Placeholder</title><rect width="100%" height="100%" fill="var(--bs-secondary-color)"></rect></svg>
          <h1 class="fw-light">Anonymous Client</h1>
          <i class="bi bi-quote" style="color: black;"></i>
          <p class="lead text-body-secondary">
            "Absolutely fantastic to work with very professional and installation conducted in fast and professional manner"
            <!--TODO: Add jumbotron-->
          </p>
          <p class="text-muted my-auto">
            We respect our client's privacy if they wish to stay anonymous
          </p>
        </div>
      </div>
    </section>

    <%-include("../public/partials/footer.ejs"); %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
