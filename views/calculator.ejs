<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <title>Carbon Calculator</title>
  </head>
  <body>
    <%-include("../public/partials/header.ejs"); %>
    <div class="container">
      <h1>Welcome To Our Carbon Calculator</h1>
      <div class="card" style="width: 18rem py-5">
        <div class="card-body">
          <form action="/calculate" method="post">
            <input
              type="number"
              name="electricity"
              required
              placeholder="electricity (kwh)"
            />
            <input
              type="number"
              name="distance"
              required
              placeholder="distance(miles)"
            />
            <button type="calculate" class="btn btn-primary btn-warning">
              Calculate Carbon
            </button>
          </form>
        </div>
      </div>
      <div class="card text-center my-5">
        <% if (locals.Co2 && locals.guest === true) { %>
        <h2>Your total Co2 is <%=Co2 %> kg</h2>
        <h2><a href="/signup">Sign Up To Save Your Results</a></h2>
        <% } else if (locals.Co2 && locals.guest !== true) {%>
        <h2>Your total Co2 is <%=Co2 %> kg</h2>
        <h2>
          Your results have been saved go to
          <span><a href="/dashboard">dashboard</a></span> to view them
        </h2>
        <% } %>
      </div>
    </div>
    <%-include("../public/partials/footer.ejs"); %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
